{
  "name": "cloudvault",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Personal cloud storage platform on Cloudflare Workers + R2",
  "type": "module",
  "scripts": {
    "dev:web": "vite",
    "dev:worker": "wrangler dev",
    "dev": "npm run build:web && wrangler dev",
    "prebuild:web": "rm -rf public/assets",
    "build:web": "vite build",
    "build": "npm run build:web && wrangler deploy --dry-run",
    "deploy": "npm run build:web && wrangler deploy",
    "types": "wrangler types",
    "tail": "wrangler tail",
    "typecheck": "tsc -p tsconfig.json && tsc -p web/tsconfig.json"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "@types/node": "^22.10.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "solid-js": "^1.9.3",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "wrangler": "^4.0.0"
  }
}
